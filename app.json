{
  "expo": {
    "name": "Forja",
    "slug": "forja",
    "scheme": "forja",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14141e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forja.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#14141e",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "package": "com.forja.app",
      "permissions": [],
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BebasNeue-Regular.ttf",
            "./assets/fonts/Syne-Regular.ttf",
            "./assets/fonts/Syne-SemiBold.ttf",
            "./assets/fonts/Syne-Bold.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Acesse suas fotos para adicionar ao treino",
          "cameraPermission": "Tire fotos para adicionar ao Forja"
        }
      ],
      "./plugins/withLegacyImagePickerChooser"
    ],
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "e2586b92-1328-454b-b86e-3e923c4964eb"
      }
    },
    "owner": "pedrohperalta"
  }
}
